{
  "name": "Common DateTime Formats (Non-Standard)",
  "description": "Popular datetime formats that are neither RFC 3339 nor ISO 8601 compliant",
  "formats": [
    {
      "name": "US Date Format",
      "pattern": "MM/DD/YYYY",
      "locale": "en-US", 
      "examples": ["09/08/2024", "1/15/2024"],
      "notes": "Month/Day/Year - ambiguous internationally"
    },
    {
      "name": "European Date Format", 
      "pattern": "DD/MM/YYYY",
      "locale": "en-EU",
      "examples": ["08/09/2024", "15/01/2024"],
      "notes": "Day/Month/Year - common in Europe"
    },
    {
      "name": "Continental European Format",
      "pattern": "DD.MM.YYYY", 
      "locale": "de-DE",
      "examples": ["08.09.2024", "15.01.2024"],
      "notes": "German/Austrian/Swiss standard"
    },
    {
      "name": "Portuguese Abbreviated (Upper)",
      "pattern": "DD-MMM-YYYY",
      "locale": "pt-BR", 
      "examples": ["09-SET-2024", "15-JAN-2024", "08-DEZ-2024", "03-FEV-2024"],
      "notes": "Brazilian Portuguese with uppercase months"
    },
    {
      "name": "Portuguese Abbreviated (Title)",
      "pattern": "DD-Mmm-YYYY", 
      "locale": "pt-PT",
      "examples": ["09-Set-2024", "15-Jan-2024", "08-Dez-2024", "03-Fev-2024"],
      "notes": "European Portuguese with title case months"
    },
    {
      "name": "French Long Format",
      "pattern": "DD MMM YYYY",
      "locale": "fr-FR",
      "examples": ["09 sept 2024", "15 janv 2024"], 
      "notes": "French abbreviated months"
    },
    {
      "name": "US DateTime Format",
      "pattern": "MM/DD/YYYY HH:MM:SS AM/PM",
      "locale": "en-US",
      "examples": ["09/08/2024 3:15:22 PM", "1/15/2024 10:30:45 AM"],
      "notes": "US format with 12-hour time"
    },
    {
      "name": "European DateTime Format", 
